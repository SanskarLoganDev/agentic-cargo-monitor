# Service E — Execution Agent
# Cloud Run environment variables file.
#
# Usage:
#   1. Copy this file:  cp .env.yaml.example .env.yaml
#   2. Fill in all values below
#   3. Use in deploy:   gcloud run deploy ... --env-vars-file services/service_e/.env.yaml
#
# .env.yaml is gitignored — never commit it with real secrets.
# For local development, values are loaded from the root .env file via python-dotenv.
#
# YAML format: KEY: "VALUE"  (not KEY=VALUE like .env files)

# ── GCP ──────────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT: "project-5b45a270-c7ca-42fd-9f6"
FIRESTORE_DATABASE: "cargo-monitor"

# ── Claude ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY: "sk-ant-YOUR_KEY_HERE"

# ── Gmail SMTP ───────────────────────────────────────────────────────────────
# Uses Gmail App Password — no third-party email service needed.
# Prerequisites:
#   1. Enable 2-Step Verification on the sending Google account.
#   2. Generate a 16-char App Password at:
#      https://myaccount.google.com/apppasswords
#      (Select app: Mail, device: any label e.g. AgenticTerps)
#   3. Use that 16-char password as GMAIL_APP_PASSWORD (not your regular password).
GMAIL_USER: "your_gmail_address@gmail.com"
GMAIL_APP_PASSWORD: "xxxx xxxx xxxx xxxx"

# ── Twilio ───────────────────────────────────────────────────────────────────
# Trial account: messages/calls go to pre-verified numbers only.
# Get credentials at https://console.twilio.com
# Trial messages include "Sent from a Twilio Trial account" prefix.
TWILIO_ACCOUNT_SID: "ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
TWILIO_AUTH_TOKEN: "your_auth_token_here"
TWILIO_PHONE_NUMBER: "+1XXXXXXXXXX"

# ── ElevenLabs ───────────────────────────────────────────────────────────────
# Free tier: 10,000 credits/month (~10 min TTS).
# Get key at https://elevenlabs.io/app/settings/api-keys
# Voice IDs: browse at https://elevenlabs.io/voice-library
# Default (Rachel): 21m00Tcm4TlvDq8ikWAM
ELEVENLABS_API_KEY: "your_elevenlabs_key_here"
ELEVENLABS_VOICE_ID: "21m00Tcm4TlvDq8ikWAM"

# ── GCS Voice Notes ───────────────────────────────────────────────────────────
# Bucket is provisioned by Terraform. Name follows the pattern: {project_id}-voice-notes
# Override here only if you used a different bucket name.
VOICE_NOTES_BUCKET: "project-5b45a270-c7ca-42fd-9f6-voice-notes"
